@{
    ViewData["Title"] = "Finance Dashboard";
}

<div style="background:linear-gradient(135deg,#4facfe,#00f2fe);min-height:100vh;padding:40px;font-family:Arial">

<h1 style="text-align:center;color:white;font-size:40px">💰 Finance Dashboard</h1>

<div style="display:flex;justify-content:center;gap:30px;margin-top:40px">

<div style="background:white;padding:30px;border-radius:15px;width:200px;text-align:center">
<h3>Total Balance</h3>
<h2 style="color:green">₹50,000</h2>
</div>

<div style="background:white;padding:30px;border-radius:15px;width:200px;text-align:center">
<h3>Income</h3>
<h2 style="color:blue">₹70,000</h2>
</div>

<div style="background:white;padding:30px;border-radius:15px;width:200px;text-align:center">
<h3>Expenses</h3>
<h2 style="color:red">₹20,000</h2>
</div>

</div>

</div>